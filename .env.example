# Copy this file to .env for local development.
# In production, set these as environment variables in the Render dashboard —
# never commit a real .env file to git.

DATABASE_URL=postgresql://user:password@host:port/dbname
JWT_SECRET=replace_with_a_long_random_string
PORT=10000

# Flutterwave (or your chosen gateway) — see paymentGateway.js
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-replace_me
FLUTTERWAVE_WEBHOOK_HASH=replace_with_a_long_random_string

# Used to build the redirect URL after a successful campaign payment
FRONTEND_ADVERTISER_URL=https://afriad-ads.vercel.app
FRONTEND_EARNER_URL=https://afriad-earn.vercel.app
